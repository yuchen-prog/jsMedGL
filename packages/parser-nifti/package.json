{
  "name": "@jsmedgl/parser-nifti",
  "version": "0.1.0",
  "description": "NIfTI file parser for jsMedgl",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gl-matrix": "^3.4.3",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}