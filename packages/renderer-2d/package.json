{
  "name": "@jsmedgl/renderer-2d",
  "version": "0.1.0",
  "description": "2D slice renderer for medical imaging (MPR views)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "medical-imaging",
    "slice-rendering",
    "MPR",
    "webgl",
    "2d-rendering"
  ],
  "author": "jsMedgl Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@jsmedgl/parser-nifti": "workspace:*",
    "@jsmedgl/parser-nifti": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
