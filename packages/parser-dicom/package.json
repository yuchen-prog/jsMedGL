{
  "name": "@jsmedgl/parser-dicom",
  "version": "0.1.0",
  "description": "DICOM file parser for jsMedgl — reads DICOM Part 10 files and produces DicomVolume compatible with renderer-2d/renderer-3d",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "medical-imaging",
    "dicom",
    "parser",
    "webgl"
  ],
  "author": "jsMedgl Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
