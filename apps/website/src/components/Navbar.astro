---
const navLinks = [
  { href: '#features', label: 'Features' },
  { href: '#demo', label: 'Demo' },
  { href: '#code', label: 'Code' },
  { href: '#comparison', label: 'Compare' },
  { href: '#roadmap', label: 'Roadmap' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-black/60 border-b border-zinc-800/50">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 32 32" fill="none" class="transition-transform duration-200 group-hover:scale-110">
        <rect width="32" height="32" rx="8" fill="#6366F1"/>
        <path d="M16 6L16 26M6 16L26 16M9 9L23 23M23 9L9 23" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <circle cx="16" cy="16" r="4" stroke="white" stroke-width="2"/>
      </svg>
      <span class="font-heading font-semibold text-lg text-zinc-100">jsMedgl</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- GitHub -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/yuchen-prog/jsMedgl"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200 border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5"
        aria-label="View on GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </nav>
</header>
